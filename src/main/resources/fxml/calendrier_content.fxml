<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.coachproductivite.controller.CalendrierController"
      spacing="22"
      style="-fx-background-color:#F6F7FB;">
    <padding>
        <Insets top="28" right="32" bottom="32" left="32"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Calendrier"
                   style="-fx-font-size:24px;-fx-font-weight:800;-fx-text-fill:#111827;"/>
            <Label fx:id="moisLabel"
                   text="..."
                   style="-fx-text-fill:#6B7280;-fx-font-size:14px;"/>
        </VBox>

        <HBox spacing="8">
            <Button text="‹" onAction="#moisPrecedent"
                    style="-fx-background-color:white;
                           -fx-border-color:#E5E7EB;
                           -fx-text-fill:#374151;
                           -fx-font-size:18px;
                           -fx-font-weight:bold;
                           -fx-min-width:40px;
                           -fx-min-height:40px;
                           -fx-background-radius:10;
                           -fx-border-radius:10;
                           -fx-cursor:hand;"/>
            <Button text="Aujourd'hui" onAction="#allerAujourdhui"
                    style="-fx-background-color:#4F46E5;
                           -fx-text-fill:white;
                           -fx-font-weight:700;
                           -fx-padding:10 16;
                           -fx-background-radius:10;
                           -fx-cursor:hand;"/>
            <Button text="›" onAction="#moisSuivant"
                    style="-fx-background-color:white;
                           -fx-border-color:#E5E7EB;
                           -fx-text-fill:#374151;
                           -fx-font-size:18px;
                           -fx-font-weight:bold;
                           -fx-min-width:40px;
                           -fx-min-height:40px;
                           -fx-background-radius:10;
                           -fx-border-radius:10;
                           -fx-cursor:hand;"/>
        </HBox>
    </HBox>

    <HBox spacing="18" VBox.vgrow="ALWAYS">

        <!-- Calendrier -->
        <VBox spacing="16"
              style="-fx-background-color:white;
                     -fx-background-radius:16;
                     -fx-border-color:#E5E7EB;
                     -fx-border-radius:16;
                     -fx-padding:20;"
              prefWidth="480" minWidth="440">

            <!-- Jours de la semaine -->
            <GridPane hgap="6" vgap="6" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                </columnConstraints>

                <Label text="Lun" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
                <Label text="Mar" GridPane.columnIndex="1" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
                <Label text="Mer" GridPane.columnIndex="2" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
                <Label text="Jeu" GridPane.columnIndex="3" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
                <Label text="Ven" GridPane.columnIndex="4" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
                <Label text="Sam" GridPane.columnIndex="5" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
                <Label text="Dim" GridPane.columnIndex="6" GridPane.rowIndex="0"
                       style="-fx-font-size:11px;-fx-font-weight:800;-fx-text-fill:#9CA3AF;"/>
            </GridPane>

            <!-- Grille des jours -->
            <GridPane fx:id="calGrid"
                      hgap="8" vgap="8"
                      alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                    <ColumnConstraints halignment="CENTER" prefWidth="52"/>
                </columnConstraints>
            </GridPane>

            <!-- Légende -->
            <HBox spacing="16" alignment="CENTER">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label style="-fx-background-color:#EF4444;-fx-background-radius:50;
                           -fx-min-width:10px;-fx-min-height:10px;"/>
                    <Label text="Urgent (≤2 jours)" style="-fx-font-size:11px;-fx-text-fill:#6B7280;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label style="-fx-background-color:#F59E0B;-fx-background-radius:50;
                           -fx-min-width:10px;-fx-min-height:10px;"/>
                    <Label text="En cours" style="-fx-font-size:11px;-fx-text-fill:#6B7280;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label style="-fx-background-color:#10B981;-fx-background-radius:50;
                           -fx-min-width:10px;-fx-min-height:10px;"/>
                    <Label text="Terminée" style="-fx-font-size:11px;-fx-text-fill:#6B7280;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label style="-fx-background-color:#4F46E5;-fx-background-radius:50;
                           -fx-min-width:10px;-fx-min-height:10px;"/>
                    <Label text="À venir" style="-fx-font-size:11px;-fx-text-fill:#6B7280;"/>
                </HBox>
            </HBox>
        </VBox>

        <!-- Panel droit -->
        <VBox spacing="14" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;
                     -fx-background-radius:16;
                     -fx-border-color:#E5E7EB;
                     -fx-border-radius:16;
                     -fx-padding:20;">

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="jourLabel"
                       text="Sélectionnez un jour"
                       style="-fx-font-size:16px;-fx-font-weight:800;-fx-text-fill:#111827;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="compteurJourLabel"
                       text=""
                       style="-fx-text-fill:#6B7280;-fx-font-size:12px;"/>
            </HBox>

            <Separator/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background:transparent;-fx-background-color:transparent;">
                <VBox fx:id="tachesJourBox" spacing="10"/>
            </ScrollPane>
        </VBox>

    </HBox>
</VBox>