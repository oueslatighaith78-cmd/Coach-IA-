<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.coachproductivite.controller.LoginController"
      style="-fx-background-color:white;">

    <!-- ===== PANNEAU GAUCHE ===== -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="500"
               style="-fx-background-color:linear-gradient(to bottom right,#4338CA 0%,#6D28D9 50%,#9333EA 100%);">

        <Circle radius="220" fill="rgba(255,255,255,0.06)"
                StackPane.alignment="TOP_RIGHT"
                translateX="120" translateY="-100"/>
        <Circle radius="140" fill="rgba(255,255,255,0.05)"
                StackPane.alignment="BOTTOM_LEFT"
                translateX="-70" translateY="90"/>

        <VBox spacing="36" alignment="CENTER" maxWidth="440">
            <padding>
                <Insets top="60" right="60" bottom="60" left="60"/>
            </padding>

            <!-- LOGO GRAPHIQUE (formes géométriques) -->
            <VBox spacing="20" alignment="CENTER">
                <StackPane>
                    <!-- Grand cercle blanc de fond -->
                    <Circle radius="42" fill="white"
                            style="-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),15,0,0,5);"/>
                    <!-- Cercle violet superposé -->
                    <Circle radius="28" fill="#4F46E5" translateX="-8" translateY="-8"/>
                    <!-- Petit cercle blanc -->
                    <Circle radius="12" fill="white" translateX="10" translateY="10"/>
                </StackPane>

                <VBox spacing="10" alignment="CENTER">
                    <HBox alignment="CENTER" spacing="0">
                        <Label text="Coach"
                               style="-fx-font-size:36px;
                                      -fx-font-weight:900;
                                      -fx-text-fill:white;
                                      -fx-letter-spacing:-1;"/>
                        <Label text="IA"
                               style="-fx-font-size:36px;
                                      -fx-font-weight:900;
                                      -fx-text-fill:#FCD34D;
                                      -fx-letter-spacing:-1;"/>
                    </HBox>
                    <Label text="L'assistant qui booste votre productivité"
                           wrapText="true"
                           alignment="CENTER"
                           style="-fx-font-size:14px;
                                  -fx-text-fill:rgba(255,255,255,0.85);
                                  -fx-font-weight:400;"/>
                </VBox>
            </VBox>

            <!-- Features avec vrais mini-badges design -->
            <VBox spacing="16"
                  style="-fx-background-color:rgba(255,255,255,0.1);
                         -fx-background-radius:20;
                         -fx-border-color:rgba(255,255,255,0.2);
                         -fx-border-radius:20;
                         -fx-border-width:1;
                         -fx-padding:26;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),20,0,0,6);">

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="22" fill="rgba(255,255,255,0.2)"/>
                        <Label text="📋"
                               style="-fx-font-size:18px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Gestion intelligente"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:14px;"/>
                        <Label text="Organisez, priorisez et suivez sans effort"
                               style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:12px;"/>
                    </VBox>
                </HBox>

                <Label style="-fx-min-height:1px;-fx-background-color:rgba(255,255,255,0.15);"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="22" fill="rgba(255,255,255,0.2)"/>
                        <Label text="⏱"
                               style="-fx-font-size:18px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Chronomètre intégré"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:14px;"/>
                        <Label text="Mesurez précisément votre temps de travail"
                               style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:12px;"/>
                    </VBox>
                </HBox>

                <Label style="-fx-min-height:1px;-fx-background-color:rgba(255,255,255,0.15);"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="22" fill="rgba(252,211,77,0.3)"/>
                        <Label text="✨"
                               style="-fx-font-size:18px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Assistant IA Gemini"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:14px;"/>
                        <Label text="Décomposez vos objectifs en étapes concrètes"
                               style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:12px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="6" alignment="CENTER">
                <Label text="« Concentrez-vous sur l'essentiel »"
                       wrapText="true"
                       alignment="CENTER"
                       style="-fx-text-fill:rgba(255,255,255,0.9);
                              -fx-font-size:13px;
                              -fx-font-style:italic;"/>
            </VBox>
        </VBox>
    </StackPane>

    <!-- ===== PANNEAU DROIT ===== -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="500"
               style="-fx-background-color:#FAFBFC;">

        <VBox alignment="CENTER" spacing="26" maxWidth="380">
            <padding>
                <Insets top="60" right="50" bottom="60" left="50"/>
            </padding>

            <!-- Header -->
            <VBox spacing="10">
                <Label text="Bon retour !"
                       style="-fx-font-size:32px;
                              -fx-font-weight:900;
                              -fx-text-fill:#0F172A;
                              -fx-letter-spacing:-0.5;"/>
                <Label text="Connectez-vous pour continuer votre progression"
                       style="-fx-text-fill:#64748B;-fx-font-size:14px;"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="8">
                <Label text="Adresse email"
                       style="-fx-font-weight:700;-fx-text-fill:#334155;-fx-font-size:12px;-fx-letter-spacing:0.3;"/>
                <TextField fx:id="emailField"
                           promptText="nom@exemple.com"
                           prefHeight="48"
                           style="-fx-background-color:white;
                                  -fx-border-color:#CBD5E1;
                                  -fx-border-radius:10;
                                  -fx-background-radius:10;
                                  -fx-border-width:1.5;
                                  -fx-padding:11 16;
                                  -fx-font-size:14px;"/>
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Mot de passe"
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-weight:700;-fx-text-fill:#334155;-fx-font-size:12px;-fx-letter-spacing:0.3;"/>
                    <Hyperlink text="Oublié ?"
                               style="-fx-text-fill:#4F46E5;-fx-font-size:11px;-fx-font-weight:700;-fx-underline:false;"/>
                </HBox>
                <StackPane>
                    <PasswordField fx:id="passwordField"
                                   promptText="••••••••"
                                   prefHeight="48"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#CBD5E1;
                                          -fx-border-radius:10;
                                          -fx-background-radius:10;
                                          -fx-border-width:1.5;
                                          -fx-padding:11 60 11 16;
                                          -fx-font-size:14px;"/>
                    <TextField fx:id="passwordVisibleField"
                               promptText="••••••••"
                               prefHeight="48"
                               visible="false" managed="false"
                               style="-fx-background-color:white;
                                      -fx-border-color:#CBD5E1;
                                      -fx-border-radius:10;
                                      -fx-background-radius:10;
                                      -fx-border-width:1.5;
                                      -fx-padding:11 60 11 16;
                                      -fx-font-size:14px;"/>
                    <Button fx:id="togglePwBtn"
                            text="👁"
                            onAction="#togglePassword"
                            StackPane.alignment="CENTER_RIGHT"
                            style="-fx-background-color:transparent;
                                   -fx-text-fill:#94A3B8;
                                   -fx-font-size:16px;
                                   -fx-padding:0 14 0 0;
                                   -fx-cursor:hand;"/>
                </StackPane>
            </VBox>

            <!-- Message -->
            <Label fx:id="messageLabel" text=""
                   wrapText="true"
                   style="-fx-font-size:12px;-fx-font-weight:700;"/>

            <!-- Bouton -->
            <Button text="Se connecter"
                    onAction="#seConnecter"
                    maxWidth="Infinity"
                    prefHeight="50"
                    style="-fx-background-color:linear-gradient(to right,#4F46E5,#7C3AED);
                           -fx-text-fill:white;
                           -fx-font-weight:800;
                           -fx-font-size:14px;
                           -fx-background-radius:10;
                           -fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(79,70,229,0.4),15,0,0,5);"/>

            <!-- Séparateur discret -->
            <Label style="-fx-min-height:1px;-fx-pref-height:1px;-fx-background-color:#E2E8F0;"
                   maxWidth="Infinity"/>

            <!-- Lien inscription -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Nouveau ici ?"
                       style="-fx-text-fill:#64748B;-fx-font-size:13px;"/>
                <Hyperlink text="Créer un compte"
                           onAction="#allerInscription"
                           style="-fx-text-fill:#4F46E5;
                                  -fx-font-weight:800;
                                  -fx-font-size:13px;
                                  -fx-underline:false;"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>