<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.coachproductivite.controller.IAController"
            style="-fx-background-color:#F6F7FB;">

    <!-- HEADER -->
    <top>
        <VBox spacing="14" style="-fx-background-color:white;
                                   -fx-border-color:transparent transparent #E5E7EB transparent;
                                   -fx-border-width:0 0 1 0;">
            <padding>
                <Insets top="20" right="28" bottom="18" left="28"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14">
                <!-- Avatar IA -->
                <StackPane>
                    <Label style="-fx-background-color:linear-gradient(to bottom right,#6366F1,#8B5CF6);
                                  -fx-min-width:46px;-fx-min-height:46px;
                                  -fx-max-width:46px;-fx-max-height:46px;
                                  -fx-background-radius:50;"/>
                    <Label text="✨"
                           style="-fx-font-size:20px;"/>
                </StackPane>

                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Assistant IA"
                           style="-fx-font-size:18px;-fx-font-weight:800;-fx-text-fill:#111827;"/>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color:#10B981;
                                      -fx-background-radius:50;
                                      -fx-min-width:8px;-fx-min-height:8px;
                                      -fx-max-width:8px;-fx-max-height:8px;"/>
                        <Label text="En ligne — propulsé par Gemini"
                               style="-fx-text-fill:#6B7280;-fx-font-size:12px;"/>
                    </HBox>
                </VBox>

                <Button text="🗑 Effacer"
                        onAction="#effacerChat"
                        style="-fx-background-color:white;
                               -fx-border-color:#E5E7EB;
                               -fx-text-fill:#6B7280;
                               -fx-font-weight:600;
                               -fx-font-size:12px;
                               -fx-padding:8 14;
                               -fx-background-radius:10;
                               -fx-border-radius:10;
                               -fx-cursor:hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ZONE DE CHAT -->
    <center>
        <ScrollPane fx:id="chatScroll"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background:transparent;
                           -fx-background-color:transparent;
                           -fx-border-color:transparent;">

            <VBox fx:id="chatBox" spacing="16">
                <padding>
                    <Insets top="24" right="28" bottom="24" left="28"/>
                </padding>

                <!-- Message de bienvenue par défaut -->
                <VBox fx:id="welcomeBox" alignment="CENTER" spacing="14"
                      style="-fx-padding:40 0;">
                    <Label text="✨"
                           style="-fx-font-size:48px;"/>
                    <Label text="Bonjour ! Comment puis-je t'aider ?"
                           style="-fx-font-size:20px;-fx-font-weight:800;-fx-text-fill:#111827;"/>
                    <Label text="Choisis une suggestion ci-dessous ou écris ta demande."
                           style="-fx-text-fill:#6B7280;-fx-font-size:13px;"
                           wrapText="true"/>

                    <!-- Suggestions cards -->
                    <FlowPane hgap="12" vgap="12" alignment="CENTER"
                              style="-fx-padding:20 0 0 0;">

                        <VBox spacing="8" onMouseClicked="#decomposer"
                              style="-fx-background-color:white;
                                     -fx-border-color:#E5E7EB;
                                     -fx-border-radius:14;
                                     -fx-background-radius:14;
                                     -fx-padding:16;
                                     -fx-cursor:hand;
                                     -fx-min-width:220px;
                                     -fx-max-width:220px;">
                            <Label text="📋" style="-fx-font-size:22px;"/>
                            <Label text="Décomposer une tâche"
                                   style="-fx-font-weight:800;-fx-text-fill:#111827;-fx-font-size:13px;"/>
                            <Label text="Découpe un gros projet en étapes claires"
                                   style="-fx-text-fill:#6B7280;-fx-font-size:11px;"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="8" onMouseClicked="#suggererPriorites"
                              style="-fx-background-color:white;
                                     -fx-border-color:#E5E7EB;
                                     -fx-border-radius:14;
                                     -fx-background-radius:14;
                                     -fx-padding:16;
                                     -fx-cursor:hand;
                                     -fx-min-width:220px;
                                     -fx-max-width:220px;">
                            <Label text="🎯" style="-fx-font-size:22px;"/>
                            <Label text="Suggérer des priorités"
                                   style="-fx-font-weight:800;-fx-text-fill:#111827;-fx-font-size:13px;"/>
                            <Label text="Trouve l'ordre optimal pour avancer"
                                   style="-fx-text-fill:#6B7280;-fx-font-size:11px;"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="8" onMouseClicked="#reformuler"
                              style="-fx-background-color:white;
                                     -fx-border-color:#E5E7EB;
                                     -fx-border-radius:14;
                                     -fx-background-radius:14;
                                     -fx-padding:16;
                                     -fx-cursor:hand;
                                     -fx-min-width:220px;
                                     -fx-max-width:220px;">
                            <Label text="✏️" style="-fx-font-size:22px;"/>
                            <Label text="Reformuler un objectif"
                                   style="-fx-font-weight:800;-fx-text-fill:#111827;-fx-font-size:13px;"/>
                            <Label text="Rends ton objectif clair et motivant"
                                   style="-fx-text-fill:#6B7280;-fx-font-size:11px;"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="8" onMouseClicked="#planifier"
                              style="-fx-background-color:white;
                                     -fx-border-color:#E5E7EB;
                                     -fx-border-radius:14;
                                     -fx-background-radius:14;
                                     -fx-padding:16;
                                     -fx-cursor:hand;
                                     -fx-min-width:220px;
                                     -fx-max-width:220px;">
                            <Label text="📅" style="-fx-font-size:22px;"/>
                            <Label text="Planifier ma semaine"
                                   style="-fx-font-weight:800;-fx-text-fill:#111827;-fx-font-size:13px;"/>
                            <Label text="Crée un planning structuré sur 7 jours"
                                   style="-fx-text-fill:#6B7280;-fx-font-size:11px;"
                                   wrapText="true"/>
                        </VBox>
                    </FlowPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ZONE DE SAISIE -->
    <bottom>
        <VBox spacing="8"
              style="-fx-background-color:white;
                     -fx-border-color:#E5E7EB transparent transparent transparent;
                     -fx-border-width:1 0 0 0;">
            <padding>
                <Insets top="16" right="28" bottom="16" left="28"/>
            </padding>

            <HBox spacing="10" alignment="CENTER">
                <TextArea fx:id="promptField"
                          promptText="Écris ta demande ici..."
                          wrapText="true"
                          prefRowCount="1"
                          HBox.hgrow="ALWAYS"
                          style="-fx-background-color:#F9FAFB;
                                 -fx-border-color:#E5E7EB;
                                 -fx-border-radius:14;
                                 -fx-background-radius:14;
                                 -fx-padding:10;
                                 -fx-font-size:13px;
                                 -fx-pref-height:48px;
                                 -fx-max-height:120px;"/>

                <Button text="➤"
                        onAction="#envoyerPrompt"
                        style="-fx-background-color:#4F46E5;
                               -fx-text-fill:white;
                               -fx-font-size:18px;
                               -fx-font-weight:800;
                               -fx-min-width:48px;
                               -fx-min-height:48px;
                               -fx-max-width:48px;
                               -fx-max-height:48px;
                               -fx-background-radius:14;
                               -fx-cursor:hand;"/>
            </HBox>

            <HBox alignment="CENTER">
                <Label fx:id="loadingLabel"
                       text=""
                       style="-fx-text-fill:#6B7280;-fx-font-size:11px;-fx-font-style:italic;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>