<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.coachproductivite.controller.InscriptionController"
      style="-fx-background-color:white;">

    <!-- ===== PANNEAU GAUCHE ===== -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="500"
               style="-fx-background-color:linear-gradient(to bottom right,#4F46E5,#7C3AED,#9333EA);">

        <Circle radius="180" fill="rgba(255,255,255,0.06)"
                StackPane.alignment="TOP_RIGHT"
                translateX="100" translateY="-80"/>
        <Circle radius="120" fill="rgba(255,255,255,0.05)"
                StackPane.alignment="BOTTOM_LEFT"
                translateX="-60" translateY="80"/>

        <VBox spacing="32" alignment="CENTER" maxWidth="420">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <VBox spacing="14" alignment="CENTER">
                <StackPane>
                    <Label style="-fx-background-color:rgba(255,255,255,0.15);
                                  -fx-min-width:80px;-fx-min-height:80px;
                                  -fx-max-width:80px;-fx-max-height:80px;
                                  -fx-background-radius:20;"/>
                    <Label text="🚀" style="-fx-font-size:36px;"/>
                </StackPane>

                <Label text="Rejoins-nous !"
                       style="-fx-font-size:32px;
                              -fx-font-weight:800;
                              -fx-text-fill:white;"/>
                <Label text="Crée ton compte gratuitement et booste ta productivité"
                       wrapText="true"
                       alignment="CENTER"
                       style="-fx-font-size:14px;
                              -fx-text-fill:rgba(255,255,255,0.85);"/>
            </VBox>

            <VBox spacing="14"
                  style="-fx-background-color:rgba(255,255,255,0.12);
                         -fx-background-radius:18;
                         -fx-border-color:rgba(255,255,255,0.2);
                         -fx-border-radius:18;
                         -fx-padding:22;">

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="🎁"
                           style="-fx-font-size:18px;
                                  -fx-background-color:rgba(255,255,255,0.2);
                                  -fx-padding:8 12;
                                  -fx-background-radius:10;"/>
                    <VBox spacing="2">
                        <Label text="100% Gratuit"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:13px;"/>
                        <Label text="Aucune carte bancaire requise"
                               style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;"/>
                    </VBox>
                </HBox>

                <Label style="-fx-min-height:1px;-fx-background-color:rgba(255,255,255,0.15);"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="⚡"
                           style="-fx-font-size:18px;
                                  -fx-background-color:rgba(255,255,255,0.2);
                                  -fx-padding:8 12;
                                  -fx-background-radius:10;"/>
                    <VBox spacing="2">
                        <Label text="Configuration rapide"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:13px;"/>
                        <Label text="Commence à organiser tes tâches immédiatement"
                               style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;"
                               wrapText="true"/>
                    </VBox>
                </HBox>

                <Label style="-fx-min-height:1px;-fx-background-color:rgba(255,255,255,0.15);"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="🔒"
                           style="-fx-font-size:18px;
                                  -fx-background-color:rgba(255,255,255,0.2);
                                  -fx-padding:8 12;
                                  -fx-background-radius:10;"/>
                    <VBox spacing="2">
                        <Label text="Données sécurisées"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:13px;"/>
                        <Label text="Tes informations restent privées"
                               style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="6" alignment="CENTER">
                <Label text="« Chaque tâche accomplie est une victoire »"
                       wrapText="true"
                       alignment="CENTER"
                       style="-fx-text-fill:rgba(255,255,255,0.9);
                              -fx-font-size:12px;
                              -fx-font-style:italic;"/>
            </VBox>
        </VBox>
    </StackPane>

    <!-- ===== PANNEAU DROIT ===== -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="500"
               style="-fx-background-color:#FAFAFB;">

        <VBox alignment="CENTER" spacing="20" maxWidth="380">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <VBox spacing="6">
                <Label text="Créer un compte"
                       style="-fx-font-size:28px;-fx-font-weight:800;-fx-text-fill:#111827;"/>
                <Label text="Quelques infos pour démarrer ton aventure"
                       style="-fx-text-fill:#6B7280;-fx-font-size:13px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Nom complet"
                       style="-fx-font-weight:700;-fx-text-fill:#374151;-fx-font-size:12px;"/>
                <TextField fx:id="nomField"
                           promptText="Votre nom et prénom"
                           prefHeight="46"
                           style="-fx-background-color:white;
                                  -fx-border-color:#E5E7EB;
                                  -fx-border-radius:12;
                                  -fx-background-radius:12;
                                  -fx-padding:11 16;
                                  -fx-font-size:13px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Adresse email"
                       style="-fx-font-weight:700;-fx-text-fill:#374151;-fx-font-size:12px;"/>
                <TextField fx:id="emailField"
                           promptText="exemple@email.com"
                           prefHeight="46"
                           style="-fx-background-color:white;
                                  -fx-border-color:#E5E7EB;
                                  -fx-border-radius:12;
                                  -fx-background-radius:12;
                                  -fx-padding:11 16;
                                  -fx-font-size:13px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Mot de passe"
                       style="-fx-font-weight:700;-fx-text-fill:#374151;-fx-font-size:12px;"/>
                <StackPane>
                    <PasswordField fx:id="passwordField"
                                   promptText="Minimum 6 caractères"
                                   prefHeight="46"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#E5E7EB;
                                          -fx-border-radius:12;
                                          -fx-background-radius:12;
                                          -fx-padding:11 50 11 16;
                                          -fx-font-size:13px;"/>
                    <TextField fx:id="passwordVisibleField"
                               promptText="Minimum 6 caractères"
                               prefHeight="46"
                               visible="false" managed="false"
                               style="-fx-background-color:white;
                                      -fx-border-color:#E5E7EB;
                                      -fx-border-radius:12;
                                      -fx-background-radius:12;
                                      -fx-padding:11 50 11 16;
                                      -fx-font-size:13px;"/>
                    <Button fx:id="togglePwBtn"
                            text="👁"
                            onAction="#togglePassword"
                            StackPane.alignment="CENTER_RIGHT"
                            style="-fx-background-color:transparent;
                                   -fx-text-fill:#9CA3AF;
                                   -fx-font-size:16px;
                                   -fx-padding:0 14 0 0;
                                   -fx-cursor:hand;"/>
                </StackPane>

                <HBox fx:id="forceContainer" spacing="4" alignment="CENTER_LEFT"
                      visible="false" managed="false">
                    <Label fx:id="forceBar1" style="-fx-min-width:80px;-fx-min-height:4px;-fx-background-color:#E5E7EB;-fx-background-radius:2;"/>
                    <Label fx:id="forceBar2" style="-fx-min-width:80px;-fx-min-height:4px;-fx-background-color:#E5E7EB;-fx-background-radius:2;"/>
                    <Label fx:id="forceBar3" style="-fx-min-width:80px;-fx-min-height:4px;-fx-background-color:#E5E7EB;-fx-background-radius:2;"/>
                    <Label fx:id="forceLabel" text="" style="-fx-font-size:10px;-fx-font-weight:700;-fx-padding:0 0 0 6;"/>
                </HBox>
            </VBox>

            <Label fx:id="messageLabel" text=""
                   wrapText="true"
                   style="-fx-font-size:12px;-fx-font-weight:700;"/>

            <Button text="Créer mon compte"
                    onAction="#sInscrire"
                    maxWidth="Infinity"
                    prefHeight="50"
                    style="-fx-background-color:linear-gradient(to right,#4F46E5,#7C3AED);
                           -fx-text-fill:white;
                           -fx-font-weight:800;
                           -fx-font-size:14px;
                           -fx-background-radius:12;
                           -fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(79,70,229,0.4),12,0,0,4);"/>

            <Label text="En créant un compte, tu acceptes nos conditions d'utilisation"
                   wrapText="true"
                   alignment="CENTER"
                   style="-fx-text-fill:#9CA3AF;-fx-font-size:10px;"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Déjà un compte ?"
                       style="-fx-text-fill:#6B7280;-fx-font-size:13px;"/>
                <Hyperlink text="Se connecter"
                           onAction="#allerLogin"
                           style="-fx-text-fill:#4F46E5;
                                  -fx-font-weight:800;
                                  -fx-font-size:13px;
                                  -fx-underline:false;"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>