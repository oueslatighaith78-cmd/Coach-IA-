<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.coachproductivite.controller.InscriptionController"
      style="-fx-background-color:white;">

    <!-- ===== PANNEAU GAUCHE ===== -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="500"
               style="-fx-background-color:linear-gradient(to bottom right,#4338CA 0%,#6D28D9 50%,#9333EA 100%);">

        <Circle radius="220" fill="rgba(255,255,255,0.06)"
                StackPane.alignment="TOP_RIGHT"
                translateX="120" translateY="-100"/>
        <Circle radius="140" fill="rgba(255,255,255,0.05)"
                StackPane.alignment="BOTTOM_LEFT"
                translateX="-70" translateY="90"/>

        <VBox spacing="36" alignment="CENTER" maxWidth="440">
            <padding>
                <Insets top="60" right="60" bottom="60" left="60"/>
            </padding>

            <!-- LOGO GRAPHIQUE identique -->
            <VBox spacing="20" alignment="CENTER">
                <StackPane>
                    <Circle radius="42" fill="white"
                            style="-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),15,0,0,5);"/>
                    <Circle radius="28" fill="#4F46E5" translateX="-8" translateY="-8"/>
                    <Circle radius="12" fill="white" translateX="10" translateY="10"/>
                </StackPane>

                <VBox spacing="10" alignment="CENTER">
                    <HBox alignment="CENTER" spacing="0">
                        <Label text="Coach"
                               style="-fx-font-size:36px;
                                      -fx-font-weight:900;
                                      -fx-text-fill:white;
                                      -fx-letter-spacing:-1;"/>
                        <Label text="IA"
                               style="-fx-font-size:36px;
                                      -fx-font-weight:900;
                                      -fx-text-fill:#FCD34D;
                                      -fx-letter-spacing:-1;"/>
                    </HBox>
                    <Label text="Rejoignez des milliers d'utilisateurs productifs"
                           wrapText="true"
                           alignment="CENTER"
                           style="-fx-font-size:14px;
                                  -fx-text-fill:rgba(255,255,255,0.85);
                                  -fx-font-weight:400;"/>
                </VBox>
            </VBox>

            <VBox spacing="16"
                  style="-fx-background-color:rgba(255,255,255,0.1);
                         -fx-background-radius:20;
                         -fx-border-color:rgba(255,255,255,0.2);
                         -fx-border-radius:20;
                         -fx-border-width:1;
                         -fx-padding:26;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),20,0,0,6);">

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="22" fill="rgba(252,211,77,0.3)"/>
                        <Label text="🎁"
                               style="-fx-font-size:18px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Entièrement gratuit"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:14px;"/>
                        <Label text="Aucun engagement, aucune carte bancaire"
                               style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:12px;"/>
                    </VBox>
                </HBox>

                <Label style="-fx-min-height:1px;-fx-background-color:rgba(255,255,255,0.15);"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="22" fill="rgba(255,255,255,0.2)"/>
                        <Label text="⚡"
                               style="-fx-font-size:18px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Configuration en 30 secondes"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:14px;"/>
                        <Label text="Commencez à organiser vos tâches immédiatement"
                               style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:12px;"
                               wrapText="true"/>
                    </VBox>
                </HBox>

                <Label style="-fx-min-height:1px;-fx-background-color:rgba(255,255,255,0.15);"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="22" fill="rgba(255,255,255,0.2)"/>
                        <Label text="🔒"
                               style="-fx-font-size:18px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Données protégées"
                               style="-fx-font-weight:800;-fx-text-fill:white;-fx-font-size:14px;"/>
                        <Label text="Vos informations restent privées et sécurisées"
                               style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:12px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="6" alignment="CENTER">
                <Label text="« Chaque tâche accomplie est une victoire »"
                       wrapText="true"
                       alignment="CENTER"
                       style="-fx-text-fill:rgba(255,255,255,0.9);
                              -fx-font-size:13px;
                              -fx-font-style:italic;"/>
            </VBox>
        </VBox>
    </StackPane>

    <!-- ===== PANNEAU DROIT ===== -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="500"
               style="-fx-background-color:#FAFBFC;">

        <VBox alignment="CENTER" spacing="22" maxWidth="380">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <VBox spacing="10">
                <Label text="Créer un compte"
                       style="-fx-font-size:30px;
                              -fx-font-weight:900;
                              -fx-text-fill:#0F172A;
                              -fx-letter-spacing:-0.5;"/>
                <Label text="Quelques informations pour démarrer"
                       style="-fx-text-fill:#64748B;-fx-font-size:14px;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Nom complet"
                       style="-fx-font-weight:700;-fx-text-fill:#334155;-fx-font-size:12px;-fx-letter-spacing:0.3;"/>
                <TextField fx:id="nomField"
                           promptText="Votre nom et prénom"
                           prefHeight="48"
                           style="-fx-background-color:white;
                                  -fx-border-color:#CBD5E1;
                                  -fx-border-radius:10;
                                  -fx-background-radius:10;
                                  -fx-border-width:1.5;
                                  -fx-padding:11 16;
                                  -fx-font-size:14px;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Adresse email"
                       style="-fx-font-weight:700;-fx-text-fill:#334155;-fx-font-size:12px;-fx-letter-spacing:0.3;"/>
                <TextField fx:id="emailField"
                           promptText="nom@exemple.com"
                           prefHeight="48"
                           style="-fx-background-color:white;
                                  -fx-border-color:#CBD5E1;
                                  -fx-border-radius:10;
                                  -fx-background-radius:10;
                                  -fx-border-width:1.5;
                                  -fx-padding:11 16;
                                  -fx-font-size:14px;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Mot de passe"
                       style="-fx-font-weight:700;-fx-text-fill:#334155;-fx-font-size:12px;-fx-letter-spacing:0.3;"/>
                <StackPane>
                    <PasswordField fx:id="passwordField"
                                   promptText="Minimum 6 caractères"
                                   prefHeight="48"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#CBD5E1;
                                          -fx-border-radius:10;
                                          -fx-background-radius:10;
                                          -fx-border-width:1.5;
                                          -fx-padding:11 60 11 16;
                                          -fx-font-size:14px;"/>
                    <TextField fx:id="passwordVisibleField"
                               promptText="Minimum 6 caractères"
                               prefHeight="48"
                               visible="false" managed="false"
                               style="-fx-background-color:white;
                                      -fx-border-color:#CBD5E1;
                                      -fx-border-radius:10;
                                      -fx-background-radius:10;
                                      -fx-border-width:1.5;
                                      -fx-padding:11 60 11 16;
                                      -fx-font-size:14px;"/>
                    <Button fx:id="togglePwBtn"
                            text="👁"
                            onAction="#togglePassword"
                            StackPane.alignment="CENTER_RIGHT"
                            style="-fx-background-color:transparent;
                                   -fx-text-fill:#94A3B8;
                                   -fx-font-size:16px;
                                   -fx-padding:0 14 0 0;
                                   -fx-cursor:hand;"/>
                </StackPane>

                <HBox fx:id="forceContainer" spacing="4" alignment="CENTER_LEFT"
                      visible="false" managed="false">
                    <Label fx:id="forceBar1" style="-fx-min-width:70px;-fx-min-height:4px;-fx-background-color:#E5E7EB;-fx-background-radius:2;"/>
                    <Label fx:id="forceBar2" style="-fx-min-width:70px;-fx-min-height:4px;-fx-background-color:#E5E7EB;-fx-background-radius:2;"/>
                    <Label fx:id="forceBar3" style="-fx-min-width:70px;-fx-min-height:4px;-fx-background-color:#E5E7EB;-fx-background-radius:2;"/>
                    <Label fx:id="forceLabel" text="" style="-fx-font-size:10px;-fx-font-weight:700;-fx-padding:0 0 0 6;"/>
                </HBox>
            </VBox>

            <Label fx:id="messageLabel" text=""
                   wrapText="true"
                   style="-fx-font-size:12px;-fx-font-weight:700;"/>

            <Button text="Créer mon compte"
                    onAction="#sInscrire"
                    maxWidth="Infinity"
                    prefHeight="50"
                    style="-fx-background-color:linear-gradient(to right,#4F46E5,#7C3AED);
                           -fx-text-fill:white;
                           -fx-font-weight:800;
                           -fx-font-size:14px;
                           -fx-background-radius:10;
                           -fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(79,70,229,0.4),15,0,0,5);"/>

            <Label text="En créant un compte, vous acceptez nos conditions d'utilisation."
                   wrapText="true"
                   alignment="CENTER"
                   style="-fx-text-fill:#94A3B8;-fx-font-size:10px;"/>

            <Label style="-fx-min-height:1px;-fx-pref-height:1px;-fx-background-color:#E2E8F0;"
                   maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Vous avez déjà un compte ?"
                       style="-fx-text-fill:#64748B;-fx-font-size:13px;"/>
                <Hyperlink text="Se connecter"
                           onAction="#allerLogin"
                           style="-fx-text-fill:#4F46E5;
                                  -fx-font-weight:800;
                                  -fx-font-size:13px;
                                  -fx-underline:false;"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>